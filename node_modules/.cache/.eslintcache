t":0},{"filePath":"66","messages":"67","suppressedMessages":"68","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"69"},{"filePath":"70","messages":"71","suppressedMessages":"72","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"73","messages":"74","suppressedMessages":"75","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"76","messages":"77","suppressedMessages":"78","errorCount":0,"fatalErrorCount":0,"warningCount":4,"fixableErrorCount":0,"fixableWarningCount":3,"source":"79"},{"filePath":"80","messages":"81","suppressedMessages":"82","errorCount":0,"fatalErrorCount":0,"warningCount":3,"fixableErrorCount":0,"fixableWarningCount":0,"source":"83"},"/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/index.js",[],[],"/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/App.js",[],[],"/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/reportWebVitals.js",[],[],"/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/portfolio/Portfolio.jsx",[],[],"/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/resume/Resume.jsx",["84","85","86","87"],[],"import React from 'react'\nimport \"./resume.css\"\nimport Data from './Data'\nimport Card from './Card'\n\nconst Resume = () => {\n  return (\n    <section className=\"resume container section\" id=\"resume\">\n      <h2 className=\"section__title\">Experiencia</h2>\n\n      <div className=\"resume__container grid\">\n        <div className=\"timeline grid\">\n          {Data.map((val, id) => {\n            if(val.category == \"education\") {\n              return (\n                <Card\n                key={id}\n                icon={val.icon}\n                title={val.title}\n                year={val.year}\n                desc={val.desc}/>\n              )\n            }\n          })}\n        </div>\n\n        <div className=\"timeline grid\">\n          {Data.map((val, index) => {\n            if(val.category == \"experience\") {\n              return (\n                <Card key={index}\n                icon={val.icon}\n                title={val.title}\n                year={val.year}\n                desc={val.desc}/>\n              )\n            }\n          })}\n        </div>\n\n      </div>\n    </section>\n  )\n}\n\nexport default Resume\n","/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/sidebar/Sidebar.jsx",["88"],[],"import React from 'react'\nimport \"./sidebar.css\"\nimport Logo from \"../../assets/logo.svg\"\nimport HomeOutlinedIcon from '@mui/icons-material/HomeOutlined';\nimport AccountCircleOutlinedIcon from '@mui/icons-material/AccountCircleOutlined';\nimport DesignServicesOutlinedIcon from '@mui/icons-material/DesignServicesOutlined';\nimport ArticleOutlinedIcon from '@mui/icons-material/ArticleOutlined';\nimport WorkOutlineOutlinedIcon from '@mui/icons-material/WorkOutlineOutlined';\nimport ContactPhoneOutlinedIcon from '@mui/icons-material/ContactPhoneOutlined';\n\nconst Sidebar = () => {\n    return (\n        <aside className='aside'>\n            <a href=\"#home\" className=\"nav__logo\">\n                <img src={Logo} alt=\"\"/>\n            </a>\n\n            <nav className='nav'>\n                <div className=\"nav__menu\">\n                    <ul className=\"nav__list\">\n                        <li className=\"nav__item\">\n                            <a href=\"#home\" className=\"nav__link\">\n                                <HomeOutlinedIcon/>\n                            </a>\n                        </li>\n\n                        <li className=\"nav__item\">\n                            <a href=\"#about\" className=\"nav__link\">\n                                <AccountCircleOutlinedIcon/>\n                            </a>\n                        </li>\n\n                        <li className=\"nav__item\">\n                            <a href=\"#services\" className=\"nav__link\">\n                                <DesignServicesOutlinedIcon/>\n                            </a>\n                        </li>\n\n                        <li className=\"nav__item\">\n                            <a href=\"#resume\" className=\"nav__link\">\n                                <ArticleOutlinedIcon/>\n                            </a>\n                        </li>\n\n                        <li className=\"nav__item\">\n                            <a href=\"#portfolio\" className=\"nav__link\">\n                                <WorkOutlineOutlinedIcon/>\n                            </a>\n                        </li>\n\n                    </ul>\n                </div>\n            </nav>\n            <div className=\"nav__footer\">\n                <span className=\"copyright\">&copy; 2023</span>\n            </div>\n        </aside>\n    )\n}\n\nexport default Sidebar\n","/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/home/Home.jsx",["89"],[],"import React from 'react'\nimport \"./home.css\"\nimport Me from \"../../assets/avatar-1.jpg\"\nimport HeaderSocials from './HeaderSocials'\nimport ScrollDown from './ScrollDown'\n\nconst Home = () => {\n  return (\n    <div>\n      <section className=\"home container\" id=\"home\">\n      \n        <div className=\"intro\">\n          <img src={Me} alt=\"\" className=\"home__img\" />\n          <h1 className=\"home__name\">Ximena Muñoz</h1>\n          <span className=\"home__education\">Estudiante de Ingeniería en Animación en la Universidad Panamericana</span>\n\n          <HeaderSocials/>\n\n          <a href=\"http://ig.me/m/munox_01\" className=\"btn\" target='_blank'>Contrátame</a>\n\n          <ScrollDown/>\n          \n        </div>\n      </section>\n    </div>\n  )\n}\n\nexport default Home\n","/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/about/About.jsx",["90"],[],"import React from 'react'\nimport \"./about.css\"\nimport Image from \"../../assets/avatar-1.jpg\"\nimport AboutBox from './AboutBox'\n\nconst About = () => {\n  return (\n    <section className=\"about container section\" id=\"about\">\n      <h2 className=\"section__title\">Acerca de Mí</h2>\n\n      <div className=\"about__container grid\">\n        <img src={Image} alt=\"\" className=\"about__img\"/>\n        <div className=\"about__data grid\">\n          <div className=\"about__info\">\n            <p className=\"about__description\"> Mi nombre es Ximena, actualmente trabajo como becaria en el área de Coordinación de Ingenierías en donde administro el sitio web y apoyo en la logística del evento Open Doors. Tengo experiencia en diseño gráfico en con los programas Photoshop e Illustrator.</p>\n            <a href=\"https://drive.google.com/file/d/1V05x19d9bDpqEBaje4JFGI07MsQ-QpMr/view?usp=sharing\" className=\"btn\" target=\"_blank\">Download CV</a>\n          </div>\n          <div className=\"about__skills grid\">\n\n            <div className=\"skills__data\">\n              <div className=\"skills__titles\">\n                <h3 className=\"skills__name\">Illustrator/Photoshop</h3>\n                <span className=\"skills__number\">75%</span>\n              </div>\n              <div className=\"skills__bar\">\n                <span className=\"skills__percentage ilttPhsh\"></span>\n              </div>\n            </div>\n\n            <div className=\"skills__data\">\n              <div className=\"skills__titles\">\n                <h3 className=\"skills__name\">Diseño Gráfico</h3>\n                <span className=\"skills__number\">75%</span>\n              </div>\n              <div className=\"skills__bar\">\n                <span className=\"skills__percentage design\"></span>\n              </div>\n            </div>\n\n            <div className=\"skills__data\">\n              <div className=\"skills__titles\">\n                <h3 className=\"skills__name\">Dibujo</h3>\n                <span className=\"skills__number\">50%</span>\n              </div>\n              <div className=\"skills__bar\">\n                <span className=\"skills__percentage drawing\"></span>\n              </div>\n            </div>\n\n            <div className=\"skills__data\">\n              <div className=\"skills__titles\">\n                <h3 className=\"skills__name\">Código</h3>\n                <span className=\"skills__number\">40%</span>\n              </div>\n              <div className=\"skills__bar\">\n                <span className=\"skills__percentage coding\"></span>\n              </div>\n            </div>\n\n          </div>\n        </div>\n      </div>\n      <AboutBox/>\n    </section>\n  )\n}\n\nexport default About\n","/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/services/Services.jsx",[],[],"/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/resume/Data.jsx",[],[],"/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/portfolio/Menu.jsx",["91"],[],"import Work1 from \"../../assets/work-1.JPG\"\nimport Work2 from \"../../assets/work-2.gif\"\nimport Work3 from \"../../assets/work-3.JPG\"\nimport Work4 from \"../../assets/work-4.jpg\"\nimport Work5 from \"../../assets/work-5.png\"\nimport Work6 from \"../../assets/work-6.jpg\"\n\nconst Menu = [\n    {\n      id: 1,\n      image: Work1,\n      title: \"Bearnardo\",\n      category: \"Diseño de Personajes\",\n      link: \"https://drive.google.com/drive/folders/1xDYWxBJAn9fLW_6-EnH6JncCXRcZYXPb?usp=share_link\",\n    },\n    {\n      id: 2,\n      image: Work2,\n      title: \"Bearnardo Animación\",\n      category: \"Animación 2D\",\n      link: \"https://drive.google.com/file/d/17N49DTjbYjV4yNXTkyeO4YVqeFICVC8E/view?usp=share_link\",\n    },\n    {\n      id: 3,\n      image: Work3,\n      title: \"Ilustración Fanart\",\n      category: \"Ilustración\",\n      link: \"https://drive.google.com/file/d/1gtXccSeuuvBTe2UldoQcxSoi7iDT1aW9/view?usp=share_link\",\n    },\n    ,\n    {\n      id: 4,\n      image: Work4,\n      title: \"Lemonade\",\n      category: \"Video\",\n      link: \"https://drive.google.com/file/d/1mvxiENzrIsjH4PUUVs9iXwQ9Dfr1HMzk/view?usp=share_link\",\n    },\n    ,\n    {\n      id: 5,\n      image: Work5,\n      title: \"Open Doors 2023\",\n      category: \"Diseño Web\",\n      link: \"https://concursoopendoors.up.edu.mx/\",\n    },\n    ,\n    {\n      id: 6,\n      image: Work6,\n      title: \"Automatización de Comunicación\",\n      category: \"Código\",\n      link: \"\",\n    },\n  ];\n\n  export default Menu","/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/resume/Card.jsx",[],[],"/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/home/ScrollDown.jsx",[],[],"/Users/ximenamunoz/Downloads/GitHub/Web-portfolio/src/components/home/HeaderSocials.jsx",["92","93","94","95"],[],"import React from 'react'\nimport InstagramIcon from '@mui/icons-material/Instagram';\nimport TwitterIcon from '@mui/icons-material/Twitter';\nimport ColorLensOutlinedIcon from '@mui/icons-material/ColorLensOutlined';\nimport LinkedInIcon from '@mui/icons-material/LinkedIn';\n\nconst HeaderSocials = () => {\n  return (\n    <div className=\"home__socials\">\n        <a href=\"https://instagram.com/munox_01?igshid=OGQ5ZDc2ODk2ZA%3D%3D&utm_source=qr\" className=\"home__social-link\" target=\"_blank\">\n            <InstagramIcon/>\n        </a>\n\n        <a href=\"https://x.com/xime_na01?s=21\" className=\"home__social-link\" target=\"_blank\">\n            <TwitterIcon/>\n        </a>\n\n        <a href=\"https://www.artstation.com/xime_munox01\" className=\"home__social-link\" target=\"_blank\">\n            <ColorLensOutlinedIcon/>\n        </a>\n        \n        <a href=\"\" className=\"home__social-link\" target=\"_blank\">\n            <LinkedInIcon/>\n        </a>\n    </div>\n  )\n}\n\nexport default HeaderSocials\n","/Users/ximenamunoz/Downloads/GitHub/Web-portfoli